{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syslog-mcp.tootie.tv/contracts/notification-rules.schema.json",
  "title": "syslog-mcp notification rule",
  "description": "Contract derived from docs/superpowers/specs/2026-05-16-digest-notifications-design.md §4-§7. Changing it requires updating the spec first. Validates a single rule object as it appears in a [[notifications.rules]] TOML array. Decoders should TOML-parse first, then validate each element against this schema.",

  "type": "object",
  "additionalProperties": false,
  "required": ["id", "severity", "match", "trigger"],

  "properties": {
    "id": {
      "type": "string",
      "description": "Stable rule identifier. kebab-case slug.",
      "pattern": "^[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "maxLength": 256
    },
    "severity": {
      "$ref": "#/$defs/severityTier"
    },
    "tag": {
      "type": "string",
      "description": "Apprise routing tag override; appended to the default severity+host tag set.",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,31}$"
    },
    "match": {
      "$ref": "#/$defs/matchClause"
    },
    "trigger": {
      "$ref": "#/$defs/trigger"
    },
    "deliver": {
      "$ref": "#/$defs/deliver"
    }
  },

  "$defs": {
    "severityTier": {
      "type": "string",
      "enum": ["info", "warn", "critical"],
      "description": "info = digest-only (never pushes as standalone alert). warn = single push, no repeat. critical = first push + repeats every repeat_seconds until acked; overrides quiet hours."
    },

    "duration": {
      "type": "string",
      "description": "humantime-style duration: '30s', '10m', '2h', '1d'.",
      "pattern": "^[0-9]+(?:ms|s|m|h|d)$"
    },

    "matchClause": {
      "type": "object",
      "additionalProperties": false,
      "description": "Logical AND across all populated operators. At least one operator is required.",
      "minProperties": 1,
      "properties": {
        "tag": {
          "type": "string",
          "description": "Exact match on the enriched syslog `tag` field."
        },
        "host": {
          "type": "string",
          "description": "Exact hostname match."
        },
        "severity_min": {
          "$ref": "#/$defs/severityTier",
          "description": "Numeric severity floor: rule matches when log severity >= this tier."
        },
        "field_eq": {
          "$ref": "#/$defs/fieldMap",
          "description": "Map of field-path => expected value. Supports metadata_json.<key> dotted paths."
        },
        "field_neq": {
          "$ref": "#/$defs/fieldMap"
        },
        "field_in": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": ["string", "integer", "boolean"] },
            "minItems": 1
          },
          "description": "Map of field-path => list of allowed values; matches if log's value is in list."
        },
        "message_contains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "description": "OR-joined list of case-insensitive substrings."
        },
        "message_regex": {
          "type": "string",
          "description": "Single anchored regex; compiled once at load. Use sparingly — slower than message_contains."
        }
      }
    },

    "fieldMap": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "integer", "boolean"]
      },
      "description": "Map of field path (e.g. http_status, auth_outcome, metadata_json.remote_ip) to expected scalar value."
    },

    "trigger": {
      "type": "object",
      "required": ["type"],
      "discriminator": { "propertyName": "type" },
      "oneOf": [
        { "$ref": "#/$defs/triggerInstant" },
        { "$ref": "#/$defs/triggerCountOverWindow" },
        { "$ref": "#/$defs/triggerSustained" }
      ]
    },

    "triggerInstant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "instant" }
      },
      "description": "Fire on every match, subject to dedup_window. No additional fields."
    },

    "triggerCountOverWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "window", "threshold"],
      "properties": {
        "type": { "const": "count_over_window" },
        "window": {
          "$ref": "#/$defs/duration",
          "description": "Sliding window over which matches are counted."
        },
        "threshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of matches within window that triggers firing."
        },
        "group_by": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Field paths whose values define grouping keys (fingerprint inputs)."
        }
      }
    },

    "triggerSustained": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "bucket_seconds", "min_buckets", "lookback_buckets"],
      "properties": {
        "type": { "const": "sustained" },
        "bucket_seconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Width of each evaluation bucket in seconds."
        },
        "min_buckets": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum number of buckets in lookback_buckets that must contain a match for the rule to fire."
        },
        "lookback_buckets": {
          "type": "integer",
          "minimum": 1,
          "description": "How many recent buckets to consider, e.g. 5 means 'last 5 buckets'."
        },
        "sustained_for_seconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Convenience: derived = bucket_seconds * min_buckets. Provided for spec compatibility."
        },
        "group_by": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },

    "deliver": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Tera template for the push title; vars: {{ host }}, {{ severity }}, {{ event_action }}, {{ metadata_json.* }}, etc."
        },
        "tag": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{0,31}$",
          "description": "Apprise tag appended to default tags. Same as top-level `tag`; deliver-level tag overrides when both are present."
        },
        "dedup_window_seconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Suppress identical fingerprints for this many seconds after first push. Per spec defaults: warn=1800, critical=600."
        },
        "repeat_seconds": {
          "type": "integer",
          "minimum": 60,
          "description": "ONLY VALID when severity = critical. Re-push every N seconds while the alert is unacked. Validation: a rule with severity != critical that sets repeat_seconds is INVALID."
        },
        "quiet_hours_override": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "respect": {
              "type": "boolean",
              "description": "When false, this rule bypasses global quiet hours. critical alerts already bypass by contract; this is for warn rules that should also bypass."
            }
          },
          "description": "Per-rule override of the global [notifications.quiet_hours] block."
        }
      }
    }
  },

  "allOf": [
    {
      "description": "repeat_seconds is only meaningful for critical rules.",
      "if": {
        "properties": { "deliver": { "required": ["repeat_seconds"] } },
        "required": ["deliver"]
      },
      "then": {
        "properties": {
          "severity": { "const": "critical" }
        }
      }
    }
  ],

  "examples": [
    {
      "id": "container-die",
      "description": "Docker container exited unexpectedly (non-zero exit).",
      "severity": "critical",
      "tag": "container",
      "match": {
        "tag": "docker",
        "field_eq": { "event_action": "die" },
        "field_neq": { "metadata_json.exit_code": "0" }
      },
      "trigger": { "type": "instant" },
      "deliver": {
        "dedup_window_seconds": 600,
        "repeat_seconds": 1800,
        "title": "container die: {{ host }} / {{ metadata_json.container_name }}"
      }
    },

    {
      "id": "authelia-mfa-bruteforce",
      "description": "5+ failed MFA attempts in 10 minutes from same remote IP.",
      "severity": "critical",
      "match": {
        "tag": "authelia",
        "field_eq": { "auth_outcome": "failure" }
      },
      "trigger": {
        "type": "count_over_window",
        "window": "10m",
        "threshold": 5,
        "group_by": ["metadata_json.remote_ip"]
      },
      "deliver": {
        "dedup_window_seconds": 3600,
        "repeat_seconds": 1800
      }
    },

    {
      "id": "varlog-full",
      "severity": "warn",
      "match": {
        "message_contains": [
          "No space left on device",
          "filesystem full",
          "/var/log: 9"
        ]
      },
      "trigger": { "type": "instant" },
      "deliver": { "dedup_window_seconds": 1800 }
    },

    {
      "id": "oom-kill",
      "severity": "critical",
      "match": {
        "tag": "kernel",
        "field_eq": { "event_action": "oom_kill" }
      },
      "trigger": { "type": "instant" },
      "deliver": { "dedup_window_seconds": 300 }
    },

    {
      "id": "fail2ban-ban",
      "severity": "warn",
      "tag": "auth",
      "match": {
        "tag": "fail2ban",
        "field_eq": { "event_action": "ban" }
      },
      "trigger": { "type": "instant" },
      "deliver": { "dedup_window_seconds": 900 }
    },

    {
      "id": "adguard-upstream-fail",
      "severity": "warn",
      "match": {
        "tag": "adguard",
        "field_eq": { "event_action": "upstream_error" }
      },
      "trigger": {
        "type": "count_over_window",
        "window": "5m",
        "threshold": 10
      },
      "deliver": { "dedup_window_seconds": 3600 }
    },

    {
      "id": "http-5xx-burst",
      "description": "Repeated 5xx from any host (per-host group_by).",
      "severity": "warn",
      "match": {
        "field_eq": { "http_status_class": "5xx" }
      },
      "trigger": {
        "type": "count_over_window",
        "window": "5m",
        "threshold": 25,
        "group_by": ["host"]
      },
      "deliver": { "dedup_window_seconds": 1800 }
    },

    {
      "id": "disk-pressure-sustained",
      "description": "Disk pressure log lines in 3 of last 5 minutes (sustained).",
      "severity": "warn",
      "match": {
        "message_contains": ["disk pressure", "/var/log:"]
      },
      "trigger": {
        "type": "sustained",
        "bucket_seconds": 60,
        "min_buckets": 3,
        "lookback_buckets": 5,
        "sustained_for_seconds": 180
      },
      "deliver": { "dedup_window_seconds": 1800 }
    }
  ]
}
