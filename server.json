{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "tv.tootie/cortex",
  "title": "Syslog MCP",
  "description": "Syslog receiver and MCP server for homelab log intelligence.",
  "repository": {
    "url": "https://github.com/jmagar/cortex",
    "source": "github"
  },
  "version": "1.8.0",
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/jmagar/cortex:v1.8.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CORTEX_RECEIVER_HOST",
          "description": "Hostname or IP of the syslog listener.",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "CORTEX_TOKEN",
          "description": "Bearer token for MCP endpoint authentication.",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "CORTEX_RECEIVER_PORT",
          "description": "Syslog listener port (UDP + TCP). Default: 1514.",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://cortex.tootie.tv/mcp"
    }
  ]
}
