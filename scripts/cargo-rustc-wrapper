#!/usr/bin/env bash
set -euo pipefail

repo="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
export CARGO_BIN_ARTIFACT_REPO="$repo"
export CARGO_BIN_ARTIFACT_LEGACY_PREFIX=CORTEX_RUSTC_WRAPPER
export CARGO_BIN_ARTIFACT_LOCAL_CRATE=cortex
export CARGO_BIN_ARTIFACT_LOCAL_BIN="${CORTEX_RUSTC_WRAPPER_LOCAL_BIN:-$HOME/.local/bin/cortex}"
export CARGO_BIN_ARTIFACT_LOCAL_PROFILES=release

helper="${CARGO_BIN_ARTIFACT_WRAPPER_HELPER:-}"
if [ -z "$helper" ]; then
  if command -v cargo-bin-artifact-wrapper >/dev/null 2>&1; then
    helper="$(command -v cargo-bin-artifact-wrapper)"
  elif [ -x /home/jmagar/.local/bin/cargo-bin-artifact-wrapper ]; then
    helper=/home/jmagar/.local/bin/cargo-bin-artifact-wrapper
  fi
fi

if [ -n "$helper" ]; then
  exec "$helper" "$@"
fi

if [ "$#" -lt 1 ]; then
  echo "usage: cargo-rustc-wrapper <rustc> [rustc-args...]" >&2
  exit 2
fi

rustc="$1"
shift

if [ -n "${CORTEX_RUSTC_WRAPPER_DELEGATE:-}" ]; then
  exec "$CORTEX_RUSTC_WRAPPER_DELEGATE" "$rustc" "$@"
elif [ "${CORTEX_RUSTC_WRAPPER_NO_SCCACHE:-0}" != "1" ] && command -v sccache-wrapper >/dev/null 2>&1; then
  exec sccache-wrapper "$rustc" "$@"
elif [ "${CORTEX_RUSTC_WRAPPER_NO_SCCACHE:-0}" != "1" ] && command -v sccache >/dev/null 2>&1; then
  exec sccache "$rustc" "$@"
else
  exec "$rustc" "$@"
fi
