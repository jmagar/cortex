# cortex environment variables
# Copy to .env and adjust for your environment.
#
# CORTEX_*     = syslog listener settings
# CORTEX_* = MCP server + storage settings
# CORTEX_API_* = always-on REST API settings — CORTEX_API_TOKEN is REQUIRED
#                for the server to start (post-v0.26 cutover).

# --- MCP server auth ---

# Bearer token for MCP endpoint authentication.
# When set, all requests to /mcp must include:
#   Authorization: Bearer <token>
# Leave unset to disable auth (LoopbackDev mode — only bind to 127.0.0.1).
CORTEX_TOKEN=your_bearer_token

# Explicitly disable MCP auth. On non-loopback binds, also set
# CORTEX_TRUSTED_GATEWAY_NO_AUTH=true after confirming an upstream gateway
# or reverse proxy enforces auth before traffic reaches cortex.
# NO_AUTH=false
# CORTEX_TRUSTED_GATEWAY_NO_AUTH=false

# Auth mode: "bearer" (default, static token only) or "oauth" (Google OAuth + JWT).
# Set to "oauth" to activate Google login flow and RS256 JWT issuance.
# CORTEX_AUTH_MODE=bearer

# Public base URL — required when AUTH_MODE=oauth.
# Used as JWT issuer and OAuth callback base. Must be reachable by users.
# Example: https://syslog.yourdomain.com
# CORTEX_PUBLIC_URL=https://syslog.example.com

# Google OAuth credentials — required when AUTH_MODE=oauth.
# Create at https://console.cloud.google.com → APIs & Services → Credentials.
# Set redirect URI to: ${CORTEX_PUBLIC_URL}/auth/google/callback
# CORTEX_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# CORTEX_GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth allowlist and client callbacks — required/supported when AUTH_MODE=oauth.
# CORTEX_AUTH_ADMIN_EMAIL=you@example.com
# CORTEX_AUTH_ALLOWED_REDIRECT_URIS=https://callback.example.com/callback
# CORTEX_AUTH_DISABLE_STATIC_TOKEN_WITH_OAUTH=true

# MCP server port
CORTEX_PORT=8080

# Optional RMCP Host/Origin validation allow-lists for reverse proxies or public DNS names.
# Comma-separated. Host entries may include ports.
# CORTEX_ALLOWED_HOSTS=syslog.example.com,syslog.example.com:443
# CORTEX_ALLOWED_ORIGINS=https://syslog.example.com

# --- Syslog listener ---

# Host to bind UDP + TCP listeners (no port here)
CORTEX_RECEIVER_HOST=your-syslog-host

# Port for syslog (UDP + TCP share the same port)
CORTEX_RECEIVER_PORT=514

# Max syslog message size in bytes
# CORTEX_MAX_MESSAGE_SIZE=8192

# Batch writer: entries per flush
# CORTEX_BATCH_SIZE=100

# Batch writer: flush interval in milliseconds
# CORTEX_FLUSH_INTERVAL=500

# --- MCP server bind ---

# Host to bind MCP HTTP server (no port here)
CORTEX_HOST=0.0.0.0

# --- Always-on REST API ---

# `/api/*` is always mounted. The server fails to start without a token.
# `syslog setup repair` generates one if missing and preserves any existing
# value on subsequent runs.
# CORTEX_API_TOKEN=your_separate_api_token

# --- Storage ---

# SQLite database path (inside container: /data/cortex.db)
CORTEX_DB_PATH=/data/cortex.db

# Connection pool size
CORTEX_POOL_SIZE=4

# Log retention in days (0 = keep forever)
CORTEX_RETENTION_DAYS=90

# --- Docker socket-proxy ingest ---

# Keep Docker's normal local/json-file/journald logging driver and have
# cortex pull container logs through read-only docker-socket-proxy endpoints.
CORTEX_DOCKER_INGEST_ENABLED=false

# Option A (simple): comma-separated hostnames, each resolved as http://<name>:2375
# CORTEX_DOCKER_HOSTS=host-a,host-b

# Option B (advanced): TOML file with per-host base_url / TLS options.
# Requires CORTEX_CONFIG_VOLUME to be mounted and the file to exist there.
# Missing file → warning logged, no hosts loaded (container keeps running).
# CORTEX_DOCKER_HOSTS_FILE=/config/docker-hosts.toml

# CORTEX_DOCKER_RECONNECT_INITIAL_MS=1000
# CORTEX_DOCKER_RECONNECT_MAX_MS=30000

# --- Homelab inventory / map ---

# Private cache root; defaults to ~/.cortex/inventory for local runs.
# CORTEX_INVENTORY_DIR=/home/cortex/.cortex/inventory

# Local config artifact sources. Compose YAMLs and reverse-proxy confs are
# copied into the private inventory cache after redaction.
# CORTEX_INVENTORY_COMPOSE_PATHS=/opt/edge/compose.yaml,/opt/media/compose.yaml
# CORTEX_INVENTORY_PROXY_PATHS=/opt/swag/nginx/proxy-confs

# SSH remote collection. If CORTEX_INVENTORY_SSH_HOSTS is unset, concrete Host
# aliases from CORTEX_INVENTORY_SSH_CONFIG are used.
# CORTEX_INVENTORY_SSH_CONFIG=/home/cortex/.ssh/config
# CORTEX_INVENTORY_SSH_HOSTS=host-a,host-b

# Background refresh defaults to every 5 minutes. Local compose/proxy file
# changes and remote Docker container events over SSH also trigger refreshes.
# CORTEX_INVENTORY_REFRESH_INTERVAL_SECS=300
# CORTEX_INVENTORY_WATCH_ENABLED=true
# CORTEX_INVENTORY_REMOTE_DOCKER_EVENTS=true

# Optional API collectors. Leave unset to skip that provider.
# CORTEX_UNRAID_URL=https://unraid.example
# CORTEX_UNRAID_API_KEY=
# CORTEX_UNIFI_URL=https://unifi.example
# CORTEX_UNIFI_API_KEY=
# CORTEX_SONARR_URL=http://sonarr:8989
# CORTEX_SONARR_API_KEY=
# CORTEX_RADARR_URL=http://radarr:7878
# CORTEX_RADARR_API_KEY=
# CORTEX_PROWLARR_URL=http://prowlarr:9696
# CORTEX_PROWLARR_API_KEY=
# CORTEX_SABNZBD_URL=http://sabnzbd:8080
# CORTEX_SABNZBD_API_KEY=
# CORTEX_QBITTORRENT_URL=http://qbittorrent:8080
# CORTEX_QBITTORRENT_USERNAME=
# CORTEX_QBITTORRENT_PASSWORD=
# CORTEX_PLEX_URL=http://plex:32400
# CORTEX_PLEX_TOKEN=
# CORTEX_TAUTULLI_URL=http://tautulli:8181
# CORTEX_TAUTULLI_API_KEY=
# CORTEX_OVERSEERR_URL=http://overseerr:5055
# CORTEX_OVERSEERR_API_KEY=

# --- Container ---

# Container runtime user/group for bind-mounted data directories.
PUID=1000
PGID=1000

# Timezone
TZ=UTC

# --- Docker Compose ---

# Rust log level (trace, debug, info, warn, error)
RUST_LOG=info

# Docker network name (must exist; use `docker network create <name>`)
DOCKER_NETWORK=cortex

# Data volume — two modes:
#   Named volume (default, portable): leave CORTEX_DATA_VOLUME unset or set to a volume name
#   Bind mount (direct CLI access):   set CORTEX_DATA_VOLUME=/absolute/host/path
# CORTEX_DATA_VOLUME=cortex-data
#
# Override the Docker volume name (default: cortex-data).
# The volume uses an explicit `name:` to prevent COMPOSE_PROJECT_NAME changes
# from orphaning the database with a stale project prefix.
# CORTEX_VOLUME_NAME=cortex-data

# Read-only config mount used for optional files such as docker-hosts.toml.
# CORTEX_CONFIG_VOLUME=./config

# Container resource limits (docker-compose.prod.yml deploy.resources.limits).
# Default memory is 2G: heavy `stats`/`sessions` aggregations over a large DB
# can spike memory, and the previous 512M limit caused OOM restarts. Raise this
# (e.g. 4G) on hosts with very large databases, or lower it on constrained
# nodes. Accepts docker memory syntax (512M, 1G, 2G, ...).
# CORTEX_MEMORY_LIMIT=2G
# CORTEX_CPU_LIMIT=1.0
