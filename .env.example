# cortex environment variables
# Copy to .env and adjust for your environment.
#
# CORTEX_RECEIVER_* / listener vars = syslog listener settings
# CORTEX_HOST / CORTEX_PORT / CORTEX_TOKEN = MCP server settings
# CORTEX_API_TOKEN = always-on REST API token — REQUIRED for the server
#                    to start (post-v0.26 cutover).
#
# Convention: every variable below is commented out and shows its default.
# Uncomment only the values you change.

# --- MCP server auth ---

# Bearer token for MCP endpoint authentication.
# When set, all requests to /mcp must include:
#   Authorization: Bearer <token>
# Generate: openssl rand -hex 32
# Leave unset to disable auth (only legal on loopback binds).
# REQUIRED if you expose port 3100 beyond loopback (CORTEX_MCP_BIND/CORTEX_HOST).
# CORTEX_TOKEN=your_bearer_token

# Explicitly disable MCP auth. On non-loopback binds, also set
# CORTEX_TRUSTED_GATEWAY_NO_AUTH=true after confirming an upstream gateway
# or reverse proxy enforces auth before traffic reaches cortex.
# WARNING: the combination disables BOTH auth and the read/admin scope gates
# (TrustedGatewayUnscoped) — never combine it with host-published ports.
# CORTEX_NO_AUTH=false
# CORTEX_TRUSTED_GATEWAY_NO_AUTH=false

# Grant the static bearer token cortex:admin in addition to cortex:read
# (enables ack_error / unack_error / notifications_test).
# CORTEX_STATIC_TOKEN_ADMIN=false

# Auth mode: "bearer" (default, static token only) or "oauth" (Google OAuth + JWT).
# Set to "oauth" to activate Google login flow and RS256 JWT issuance.
# CORTEX_AUTH_MODE=bearer

# Public base URL — required when CORTEX_AUTH_MODE=oauth.
# Used as JWT issuer and OAuth callback base. Must be reachable by users.
# Example: https://syslog.yourdomain.com
# CORTEX_PUBLIC_URL=https://syslog.example.com

# Google OAuth credentials — required when CORTEX_AUTH_MODE=oauth.
# Create at https://console.cloud.google.com → APIs & Services → Credentials.
# Set redirect URI to: ${CORTEX_PUBLIC_URL}/auth/google/callback
# CORTEX_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# CORTEX_GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth allowlist and client callbacks — required/supported when CORTEX_AUTH_MODE=oauth.
# CORTEX_AUTH_ADMIN_EMAIL=you@example.com
# CORTEX_AUTH_ALLOWED_REDIRECT_URIS=https://callback.example.com/callback
# CORTEX_AUTH_DISABLE_STATIC_TOKEN_WITH_OAUTH=true

# --- MCP server bind ---

# Host to bind MCP HTTP server inside the process (no port here).
# Default is loopback; non-loopback binds require CORTEX_TOKEN, OAuth, or the
# trusted-gateway pair above.
# CORTEX_HOST=127.0.0.1

# MCP server port (shared HTTP listener: /mcp, /health, /v1/logs, /v1/heartbeats)
# CORTEX_PORT=3100

# Docker Compose: host interface the container's port 3100 is published on.
# Default 127.0.0.1 (loopback-only). Set to 0.0.0.0 (or a specific interface
# IP) only together with CORTEX_TOKEN.
# CORTEX_MCP_BIND=127.0.0.1

# Optional RMCP Host/Origin validation allow-lists for reverse proxies or public DNS names.
# Comma-separated. Host entries may include ports.
# CORTEX_ALLOWED_HOSTS=syslog.example.com,syslog.example.com:443
# CORTEX_ALLOWED_ORIGINS=https://syslog.example.com

# --- Syslog listener ---

# Host to bind UDP + TCP listeners (no port here)
# CORTEX_RECEIVER_HOST=0.0.0.0

# Port for syslog (UDP + TCP share the same port).
# Keep 1514 — binding 514 requires root/CAP_NET_BIND_SERVICE and will fail in
# the unprivileged container. Redirect 514→1514 with iptables instead
# (see README "Exposing port 514").
# CORTEX_RECEIVER_PORT=1514

# Max syslog message size in bytes
# CORTEX_MAX_MESSAGE_SIZE=8192

# Maximum simultaneous TCP syslog connections
# CORTEX_MAX_TCP_CONNECTIONS=512

# Idle timeout per TCP read before closing inactive connections (seconds)
# CORTEX_TCP_IDLE_TIMEOUT_SECS=300

# Batch writer: entries per flush
# CORTEX_BATCH_SIZE=100

# Batch writer: flush interval in milliseconds
# CORTEX_FLUSH_INTERVAL=500

# Internal parsed-message queue capacity before listener backpressure
# CORTEX_WRITE_CHANNEL_CAPACITY=10000

# Optional CIDR allowlist for syslog senders. When set, UDP packets and TCP
# connections from non-matching addresses are silently dropped.
# Format: comma-separated <ip>/<prefix_len> entries.
# CORTEX_ALLOWED_SOURCE_CIDRS=10.0.0.0/8,192.168.0.0/16

# --- Always-on REST API ---

# `/api/*` is always mounted. The server fails to start without a token.
# `cortex setup repair` generates one if missing and preserves any existing
# value on subsequent runs.
# CORTEX_API_TOKEN=your_separate_api_token

# --- Storage ---

# SQLite database path (inside container: /data/cortex.db)
# CORTEX_DB_PATH=/data/cortex.db

# Connection pool size (MCP reads get pool_size - 1 permits; one connection
# is reserved for the ingest writer)
# CORTEX_POOL_SIZE=4

# Log retention in days (0 = keep forever). Purge runs hourly; err+ severities
# are exempt from retention aging. See README "Retention Policy".
# CORTEX_RETENTION_DAYS=90

# --- Storage budget ---

# Logical DB size guard: breach deletes oldest logs until the recovery target.
# CORTEX_MAX_DB_SIZE_MB=1024
# CORTEX_RECOVERY_DB_SIZE_MB=900

# Free-disk guard: DISABLED by default (0). When enabled, a breach BLOCKS
# writes (with hysteresis via the recovery target) — it does not delete data.
# CORTEX_MIN_FREE_DISK_MB=0
# CORTEX_RECOVERY_FREE_DISK_MB=0

# Storage budget enforcement interval (seconds, minimum 5) and chunk size
# CORTEX_CLEANUP_INTERVAL_SECS=60
# CORTEX_CLEANUP_CHUNK_SIZE=2000

# err+ floor: high-severity rows received within this window are protected
# from disk-pressure deletion, capped per source IP. 0 disables the floor.
# CORTEX_ERR_FLOOR_WINDOW_HOURS=24
# CORTEX_ERR_FLOOR_PER_SOURCE_CAP=10000

# FTS5 incremental-merge page budget per call (0 = built-in default of 500;
# range 0..=10000)
# CORTEX_FTS_MERGE_PAGES=0

# --- Enrichment / scrubbing ---

# Best-effort credential scrubbing on AI-source records
# CORTEX_SCRUB_PROMPTS=true

# Gate Authelia/AdGuard severity reclassification to a trusted source IP prefix
# CORTEX_AUTHELIA_SOURCE_IP=
# CORTEX_ADGUARD_SOURCE_IP=

# --- Error detection ---

# Background error-signature scan job (feeds unaddressed_errors / ack_error)
# CORTEX_ERROR_DETECTION_ENABLED=false
# CORTEX_ERROR_DETECTION_SCAN_INTERVAL_SECS=3600

# --- Notifications (Apprise) ---

# Push notifications via an Apprise API endpoint.
# CORTEX_NOTIFICATIONS_ENABLED=false
# CORTEX_NOTIFICATIONS_APPRISE_URL=http://apprise:8000

# Per-rule evaluator toggles live in config.toml [notifications.evaluators]
# (not env vars): oom_kill, container_die_nonzero, fail2ban_ban,
# authelia_mfa_fail, disk_fill, ingest_queue_pressure, and ingest_silence.
# ingest_silence (default true) fires a critical alert when the DB has logs
# but the newest row is older than ingest_silence_threshold_secs (default
# 900). An empty DB never fires.
#   [notifications.evaluators]
#   ingest_silence = true
#   ingest_silence_threshold_secs = 900

# --- Heartbeat agent ---

# Used by `cortex heartbeat agent` / `cortex setup heartbeat-agent install`.
# Target is the cortex ingest endpoint (POST /v1/heartbeats on port 3100);
# token must match CORTEX_TOKEN when auth is enabled.
# CORTEX_HEARTBEAT_TARGET=http://cortex-host:3100
# CORTEX_HEARTBEAT_TOKEN=

# --- Docker socket-proxy ingest ---

# Keep Docker's normal local/json-file/journald logging driver and have
# cortex pull container logs through read-only docker-socket-proxy endpoints.
# CORTEX_DOCKER_INGEST_ENABLED=false

# Option A (simple): comma-separated hostnames, each resolved as http://<name>:2375
# CORTEX_DOCKER_HOSTS=host-a,host-b

# Option B (advanced): TOML file with per-host base_url / TLS options.
# The file must be mounted into the container (e.g. under /cortex-home).
# Missing file → warning logged, no hosts loaded (container keeps running).
# CORTEX_DOCKER_HOSTS_FILE=/cortex-home/docker-hosts.toml

# CORTEX_DOCKER_EXCLUDED_CONTAINERS=noisy-container-a,noisy-container-b
# CORTEX_DOCKER_RECONNECT_INITIAL_MS=1000
# CORTEX_DOCKER_RECONNECT_MAX_MS=30000

# --- Homelab inventory / map ---

# Private cache root; defaults to ~/.cortex/inventory for local runs.
# CORTEX_INVENTORY_DIR=/home/cortex/.cortex/inventory

# Local config artifact sources. Compose YAMLs and reverse-proxy confs are
# copied into the private inventory cache after redaction.
# CORTEX_INVENTORY_COMPOSE_PATHS=/opt/edge/compose.yaml,/opt/media/compose.yaml
# CORTEX_INVENTORY_PROXY_PATHS=/opt/swag/nginx/proxy-confs
# CORTEX_INVENTORY_PROJECT_ROOTS=/home/you/workspace

# SSH remote collection. If CORTEX_INVENTORY_SSH_HOSTS is unset, concrete Host
# aliases from CORTEX_INVENTORY_SSH_CONFIG are used.
# CORTEX_INVENTORY_SSH_CONFIG=/home/cortex/.ssh/config
# CORTEX_INVENTORY_SSH_HOSTS=host-a,host-b

# SSH tuning. Strict host-key checking is the default; TOFU bootstrap is
# explicit opt-in. Point known_hosts at a managed file for fleet automation.
# CORTEX_INVENTORY_SSH_KNOWN_HOSTS=/home/cortex/.ssh/known_hosts
# CORTEX_INVENTORY_SSH_TRUST_ON_FIRST_USE=false
# CORTEX_INVENTORY_SSH_MAX_CONCURRENT=8
# CORTEX_INVENTORY_SSH_RETRY_ATTEMPTS=1
# CORTEX_INVENTORY_SSH_RETRY_INITIAL_BACKOFF_MS=250

# Collection deadlines (seconds)
# CORTEX_INVENTORY_COLLECTION_DEADLINE_SECS=45
# CORTEX_INVENTORY_COLLECTOR_DEADLINE_SECS=12
# CORTEX_INVENTORY_PROBE_DEADLINE_SECS=5

# Background refresh defaults to every 5 minutes. Local compose/proxy file
# changes also trigger refreshes. Remote Docker event streams over SSH are
# opt-in because they maintain one persistent SSH session per selected host.
# CORTEX_INVENTORY_REFRESH_INTERVAL_SECS=300
# CORTEX_INVENTORY_WATCH_ENABLED=true
# CORTEX_INVENTORY_REMOTE_DOCKER_EVENTS=false

# Optional API collectors. Leave unset to skip that provider.
# CORTEX_UNRAID_URL=https://unraid.example
# CORTEX_UNRAID_API_KEY=
# CORTEX_UNIFI_URL=https://unifi.example
# CORTEX_UNIFI_API_KEY=
# CORTEX_SONARR_URL=http://sonarr:8989
# CORTEX_SONARR_API_KEY=
# CORTEX_RADARR_URL=http://radarr:7878
# CORTEX_RADARR_API_KEY=
# CORTEX_PROWLARR_URL=http://prowlarr:9696
# CORTEX_PROWLARR_API_KEY=
# CORTEX_SABNZBD_URL=http://sabnzbd:8080
# CORTEX_SABNZBD_API_KEY=
# CORTEX_QBITTORRENT_URL=http://qbittorrent:8080
# CORTEX_PLEX_URL=http://plex:32400
# CORTEX_PLEX_TOKEN=
# CORTEX_TAUTULLI_URL=http://tautulli:8181
# CORTEX_TAUTULLI_API_KEY=
# CORTEX_OVERSEERR_URL=http://overseerr:5055
# CORTEX_OVERSEERR_API_KEY=

# --- Container ---

# Container runtime user/group for bind-mounted data directories.
# CORTEX_UID=1000
# CORTEX_GID=1000

# --- Docker Compose ---

# Rust log level (trace, debug, info, warn, error)
# RUST_LOG=info

# Docker network name (must exist; use `docker network create <name>`)
# DOCKER_NETWORK=cortex

# Host-side syslog port published to container port 1514 (e.g. set 514 with
# the container still binding 1514).
# CORTEX_RECEIVER_HOST_PORT=1514

# Env file the Compose service loads (optional).
# CORTEX_ENV_FILE=.env

# --- Managed file-tail ingest ---
#
# Sources are stored in <data-dir>/file-tails.json, where <data-dir> is the
# parent directory of CORTEX_DB_PATH. Manage them at runtime:
#
#   cortex file-tail add --id swag-access \
#     --path /file-tail-root/swag/log/nginx/access.log \
#     --tag swag-access --hostname squirts --facility local4
#   cortex file-tail list --json
#
# The default starts at EOF; add --from-start only for intentional backfills.
# REST /api/file-tails is additionally gated by X-Cortex-Admin-Token.
# CORTEX_API_ADMIN_TOKEN=change-me-admin-token
# Host directory mounted read-only at /file-tail-root by Compose.
# CORTEX_FILE_TAIL_LOG_VOLUME=/var/log
# Comma-separated container roots file-tail may read from.
# CORTEX_FILE_TAIL_ALLOWED_ROOTS=/file-tail-root,/var/log,/host/var/log,/logs,/mnt,/tmp

# Shared cortex home (inventory cache, setup env) mounted at /cortex-home.
# CORTEX_HOME_VOLUME=~/.cortex

# Workspace mounted read-only for project inventory collection.
# CORTEX_WORKSPACE_VOLUME=~/workspace

# Image tag used by docker-compose.prod.yml (kept in version canon; the
# default tracks the current release).
# CORTEX_VERSION=1.15.1

# Data volume — two modes:
#   Named volume (default, portable): leave CORTEX_DATA_VOLUME unset or set to a volume name
#   Bind mount (direct CLI access):   set CORTEX_DATA_VOLUME=/absolute/host/path
# CORTEX_DATA_VOLUME=cortex-data
#
# Override the Docker volume name (default: cortex-data).
# The volume uses an explicit `name:` to prevent COMPOSE_PROJECT_NAME changes
# from orphaning the database with a stale project prefix.
# CORTEX_VOLUME_NAME=cortex-data

# SSH key directory mounted read-only into the container for inventory SSH
# collection. Defaults to a DEDICATED key dir — never point this at ~/.ssh
# (lateral-movement risk; see docs/SECURITY.md "SSH key exposure").
# CORTEX_SSH_VOLUME=~/.cortex/ssh

# Container resource limits (docker-compose.prod.yml deploy.resources.limits).
# Default memory is 2G: heavy `stats`/`sessions` aggregations over a large DB
# can spike memory, and the previous 512M limit caused OOM restarts. Raise this
# (e.g. 4G) on hosts with very large databases, or lower it on constrained
# nodes. Accepts docker memory syntax (512M, 1G, 2G, ...).
# CORTEX_MEMORY_LIMIT=2G
# CORTEX_CPU_LIMIT=1.0
