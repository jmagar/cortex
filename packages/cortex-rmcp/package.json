    "claude-code",
    "codex",
    "gemini",
    "homelab",
    "logs",
    "observability",
    "sqlite",
    "syslog",
    "otlp",
    "docker",
    "log-aggregation",
    "ai",
    "llm"
  ],
  "mcpName": "ai.dinglebear/cortex-rmcp",
  "binaryVersion": "3.10.0",
  "author": {
    "name": "dinglebear.ai",
    "url": "https://dinglebear.ai"
  }
